---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";
import models from "@/data/models.json";

const pageTitle = "AI Models";
const pageDesc =
  "Machine learning models I've trained, fine-tuned, quantized, or otherwise worked on.";
---

<Layout title={`${pageTitle} | ${SITE.title}`} description={pageDesc}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="mx-auto w-full max-w-app px-4 pb-12">
    <section id="models" class="!px-0">
      <h1 class="text-2xl font-semibold tracking-wide sm:text-3xl">
        {pageTitle}
      </h1>
      <p class="mt-2 mb-8 italic opacity-80">{pageDesc}</p>

      <ul class="grid grid-cols-1 gap-5">
        {
          models.map(model => (
            <li class="group rounded-lg border border-border bg-muted/10 p-5 transition-all hover:border-accent hover:bg-muted/20">
              <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                <a
                  href={model.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-lg font-semibold text-accent decoration-dashed underline-offset-4 group-hover:underline"
                >
                  {model.name}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  >
                    <path d="M9 15l6 -6" />
                    <path d="M11 6h-3a3 3 0 0 0 -3 3v8a3 3 0 0 0 3 3h8a3 3 0 0 0 3 -3v-3" />
                    <path d="M15 6h4v4" />
                  </svg>
                </a>
                {model.role && (
                  <span class="w-fit rounded-full border border-accent/40 px-3 py-0.5 text-xs font-medium tracking-wide text-accent">
                    {model.role}
                  </span>
                )}
              </div>

              <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1 text-sm opacity-80">
                {model.task && (
                  <span>
                    <span class="font-semibold">Task:</span> {model.task}
                  </span>
                )}
                {model.baseModel && (
                  <span>
                    <span class="font-semibold">Base:</span> {model.baseModel}
                  </span>
                )}
                {model.repo && (
                  <span>
                    <span class="font-semibold">Repo:</span> {model.repo}
                  </span>
                )}
              </div>

              <p class="mt-3 leading-relaxed">{model.description}</p>

              {model.tags && model.tags.length > 0 && (
                <ul class="mt-4 flex flex-wrap gap-2">
                  {model.tags.map(tag => (
                    <li class="rounded-md bg-muted/40 px-2.5 py-0.5 text-xs font-medium">
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
